# Copy this to .env.local (already gitignored) and fill in real values.

# URL of the Python AI service (FastAPI/Flask). Next.js's /api/chat route
# proxies to {PYTHON_API_URL}/chat. Leave unset and the chat widget will
# just use offline mock replies.
PYTHON_API_URL=http://localhost:8000

# Only needed if the Mistral key ends up living on the Next.js side instead
# of the Python side — most likely it belongs in the Python service's own
# .env, not here. Keeping the placeholder in case that changes.
# MISTRAL_API_KEY=
