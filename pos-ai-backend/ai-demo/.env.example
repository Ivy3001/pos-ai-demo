# Copy to .env (gitignored) and fill in.

# If set, the service calls the real Mistral API. If left blank/unset,
# the service runs in catalog-aware demo mode (no external calls).
MISTRAL_API_KEY=

# Optional: override the default model.
MISTRAL_MODEL=mistral-small-latest

# Origin of your Next.js frontend, for CORS. Default is fine for local dev.
FRONTEND_URL=http://localhost:3000
